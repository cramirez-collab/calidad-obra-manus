{
  "query": "\nSELECT \n  e.id AS empresa_id,\n  e.nombre AS empresa,\n  e.proyectoId,\n  p.nombre AS proyecto,\n  COALESCE(esp.nombre, 'Sin especialidad') AS especialidad\nFROM empresas e\nLEFT JOIN proyectos p ON e.proyectoId = p.id\nLEFT JOIN especialidades esp ON e.especialidadId = esp.id\nWHERE e.activo = true\nORDER BY p.nombre, e.nombre;\n",
